import { Theme } from "theme.slint";
import { ComboBox } from "std-widgets.slint";
import { AnnotationTreeRow, ColorPaletteEntry } from "annotations-sidebar-types.slint";
import {
    ColorSwatchButton,
    ContextMenuRow,
    ExportIconButton,
    PaletteSwatchButton,
    TreeIconButton,
} from "annotations-sidebar-widgets.slint";

export component AnnotationsSidebar inherits Rectangle {
    in property <[string]> source-options: ["Local"];
    in property <int> source-index: 0;
    in property <[AnnotationTreeRow]> tree-items: [];
    in property <string> empty-state-text: "";
    in property <bool> can-export: false;
    in property <bool> can-delete-set: false;
    in-out property <string> selected-set-id: "";
    in property <string> selected-set-name: "";
    in-out property <string> editing-set-id: "";
    out property <bool> capture-hotkeys: editing-set-id != "";
    property <length> tree-scroll-y: 0px;
    property <string> rename-draft-text: "";
    property <[ColorPaletteEntry]> color-palette: [
        { hex: "#FF355E", swatch: #FF355E },
        { hex: "#FF7A00", swatch: #FF7A00 },
        { hex: "#E7FF00", swatch: #E7FF00 },
        { hex: "#39FF14", swatch: #39FF14 },
        { hex: "#00F5D4", swatch: #00F5D4 },
        { hex: "#4D96FF", swatch: #4D96FF },
        { hex: "#6C63FF", swatch: #6C63FF },
        { hex: "#9D4EDD", swatch: #9D4EDD },
        { hex: "#FF4FD8", swatch: #FF4FD8 },
        { hex: "#F15BB5", swatch: #F15BB5 },
        { hex: "#43AA8B", swatch: #43AA8B },
        { hex: "#577590", swatch: #577590 },
        { hex: "#FF8A5B", swatch: #FF8A5B },
        { hex: "#FFD166", swatch: #FFD166 },
        { hex: "#00BBF9", swatch: #00BBF9 },
        { hex: "#FFFFFF", swatch: #FFFFFF },
    ];

    callback source-selected(string);
    callback create-set-clicked();
    callback export-clicked();
    callback request-delete-set(string, string);
    callback delete-set-confirmed(string);
    callback delete-annotation-clicked(string);
    callback rename-set-committed(string, string);
    callback row-clicked(string);
    callback toggle-set(string);
    callback toggle-set-visibility(string, bool);
    callback set-set-color(string, string);

    property <bool> context-menu-visible: false;
    property <length> context-menu-x: 0px;
    property <length> context-menu-y: 0px;
    property <string> context-target-id: "";
    property <string> context-target-name: "";
    property <bool> context-target-is-set: false;
    property <string> pending-context-action: "";
    property <string> pending-context-id: "";
    property <string> pending-context-name: "";
    property <bool> pending-context-is-set: false;
    property <bool> color-menu-visible: false;
    property <length> color-menu-x: 0px;
    property <length> color-menu-y: 0px;
    property <string> color-target-id: "";
    property <string> active-tooltip:
        source-selector.has-focus ? "Source" : new-set-button.hovered ? new-set-button.tooltip-text : export-button.hovered ? export-button.tooltip-text : "";
    property <length> tooltip-center-x:
        source-selector.has-focus ? source-container.x + source-container.width / 2 : new-set-button.hovered ? new-set-button.x + new-set-button.width / 2 : export-button.hovered ? export-button.x + export-button.width / 2 : 0px;

    background: Theme.surface;

    action-dispatch := Timer {
        interval: 1ms;
        running: false;
        triggered => {
            self.running = false;
            if root.pending-context-action == "rename-local" {
                root.editing-set-id = root.pending-context-id;
            } else if root.pending-context-action == "delete-set" {
                root.request-delete-set(root.pending-context-id, root.pending-context-name);
            } else if root.pending-context-action == "delete-annotation" {
                root.delete-annotation-clicked(root.pending-context-id);
            }
            root.pending-context-action = "";
            root.pending-context-id = "";
            root.pending-context-name = "";
            root.pending-context-is-set = false;
        }
    }

    function confirm-active-rename() {
        if root.editing-set-id != "" {
            root.rename-set-committed(root.editing-set-id, root.rename-draft-text);
            root.editing-set-id = "";
        }
    }

    function open-context-menu(target-id: string, target-name: string, is-set: bool, local-x: length, local-y: length) {
        root.context-target-id = target-id;
        root.context-target-name = target-name;
        root.context-target-is-set = is-set;
        root.context-menu-x = local-x;
        root.context-menu-y = local-y;
        root.context-menu-visible = true;
        root.color-menu-visible = false;
    }

    function queue-context-action(action: string, target-id: string, target-name: string, is-set: bool) {
        root.pending-context-action = action;
        root.pending-context-id = target-id;
        root.pending-context-name = target-name;
        root.pending-context-is-set = is-set;
        root.context-menu-visible = false;
        action-dispatch.start();
    }

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-top: 10px;
        padding-right: 10px;
        padding-bottom: 10px;
        padding-left: 10px;
        spacing: 10px;

        HorizontalLayout {
            spacing: 8px;

            source-container := Rectangle {
                horizontal-stretch: 1;
                height: 28px;
                background: transparent;

                source-selector := ComboBox {
                    width: parent.width;
                    height: parent.height;
                    model: root.source-options;
                    current-index: root.source-index;
                    selected(index) => {
                        root.source-selected(index);
                    }
                }
            }

            new-set-button := ExportIconButton {
                icon-source: @image-url("icons/new_annotation_set.svg");
                tooltip-text: "New Annotation Set";
                clicked => {
                    root.confirm-active-rename();
                    root.create-set-clicked();
                }
            }

            export-button := ExportIconButton {
                icon-source: @image-url("icons/export.svg");
                tooltip-text: "Export Annotations";
                enabled: root.can-export;
                clicked => {
                    root.confirm-active-rename();
                    root.export-clicked();
                }
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: transparent;
            border-radius: 4px;
            border-width: 1px;
            border-color: Theme.border;

            if root.tree-items.length == 0: Rectangle {
                width: parent.width;
                height: parent.height;
                background: transparent;

                Text {
                    x: 14px;
                    y: 14px;
                    width: parent.width - 28px;
                    text: root.empty-state-text;
                    color: Theme.text-secondary;
                    font-size: 12px;
                    wrap: word-wrap;
                }
            }

            tree-flick := Flickable {
                width: parent.width;
                height: parent.height;
                viewport-height: tree-layout.preferred-height;
                viewport-y: root.tree-scroll-y;
                interactive: root.tree-items.length > 0;

                changed viewport-y => {
                    root.tree-scroll-y = self.viewport-y;
                }

                tree-layout := VerticalLayout {
                    width: parent.width;
                    spacing: 0px;

                    for row[idx] in root.tree-items: Rectangle {
                        width: parent.width;
                        height: 32px;
                        background: (row.is-set && root.selected-set-id == row.row-id) ? #4da3d930 : row-touch.has-hover ? #ffffff10 : transparent;

                        row-touch := TouchArea {
                            clicked => {
                                root.confirm-active-rename();
                                root.selected-set-id = row.is-set ? row.row-id : row.parent-set-id;
                                root.row-clicked(row.row-id);
                            }

                            double-clicked => {
                                if row.is-set {
                                    root.confirm-active-rename();
                                    root.selected-set-id = row.row-id;
                                    root.rename-draft-text = row.label;
                                    root.editing-set-id = row.row-id;
                                }
                            }

                            pointer-event(e) => {
                                if e.kind == PointerEventKind.down && e.button == PointerEventButton.right {
                                    root.confirm-active-rename();
                                    root.open-context-menu(
                                        row.row-id,
                                        row.label,
                                        row.is-set,
                                        self.absolute-position.x + self.mouse-x - root.absolute-position.x,
                                        self.absolute-position.y + self.mouse-y - root.absolute-position.y,
                                    );
                                }
                            }
                        }

                        HorizontalLayout {
                            padding-left: (8 + row.indent * 18) * 1px;
                            padding-right: 6px;
                            spacing: 1px;

                            if row.is-set: Rectangle {
                                width: 12px;
                                height: parent.height;
                                background: transparent;

                                Text {
                                    text: row.is-collapsed ? "▸" : "▾";
                                    color: Theme.text-secondary;
                                    font-size: 12px;
                                    vertical-alignment: center;
                                }

                                set-expander-touch := TouchArea {
                                    width: parent.width;
                                    height: parent.height;
                                    clicked => {
                                        root.toggle-set(row.row-id);
                                    }
                                }
                            }

                            if !row.is-set: Rectangle {
                                width: 12px;
                                height: parent.height;
                                background: transparent;
                                opacity: row.visible ? 1.0 : 0.65;

                                Rectangle {
                                    x: 3px;
                                    y: (parent.height - self.height) / 2;
                                    width: 6px;
                                    height: 6px;
                                    border-radius: 3px;
                                    background: rgb(row.color-r, row.color-g, row.color-b);
                                }
                            }

                            if root.editing-set-id == row.row-id && row.is-set: Rectangle {
                                horizontal-stretch: 1;
                                height: 22px;
                                y: (parent.height - self.height) / 2;
                                background: root.selected-set-id == row.row-id ? #0f1419f2 : #11161d;
                                border-radius: 3px;
                                border-width: 1px;
                                border-color: rename-input.has-focus ? Theme.accent : #ffffff24;

                                rename-input := TextInput {
                                    x: 5px;
                                    y: 2px;
                                    width: parent.width - 10px;
                                    height: parent.height - 4px;
                                    text: row.label;
                                    changed text => {
                                        root.rename-draft-text = self.text;
                                    }
                                    font-size: 12px;
                                    color: Theme.text-primary;
                                    selection-background-color: Theme.accent;
                                    selection-foreground-color: #ffffff;
                                    text-cursor-width: 1px;
                                    vertical-alignment: center;
                                    accepted => {
                                        root.confirm-active-rename();
                                    }
                                    key-pressed(e) => {
                                        if e.text == Key.Escape {
                                            root.editing-set-id = "";
                                            accept
                                        } else {
                                            reject
                                        }
                                    }
                                    changed has-focus => {
                                        if !self.has-focus && root.editing-set-id == row.row-id {
                                            root.confirm-active-rename();
                                        }
                                    }
                                }

                                focus-rename-input := Timer {
                                    interval: 1ms;
                                    running: true;
                                    triggered => {
                                        self.running = false;
                                        root.rename-draft-text = row.label;
                                        rename-input.focus();
                                        rename-input.select-all();
                                    }
                                }
                            }

                            if !(root.editing-set-id == row.row-id && row.is-set): Rectangle {
                                horizontal-stretch: 1;
                                vertical-stretch: 1;
                                background: transparent;

                                if row.is-set: Rectangle {
                                    width: parent.width;
                                    height: parent.height;
                                    background: transparent;

                                    set-label := Text {
                                        x: 0px;
                                        y: 0px;
                                        width: min(self.preferred-width, max(0px, parent.width - 4px - set-count.preferred-width));
                                        height: parent.height;
                                        text: row.label;
                                        color: row.visible ? Theme.text-primary : Theme.text-secondary;
                                        font-size: 12px;
                                        font-weight: 600;
                                        vertical-alignment: center;
                                        overflow: elide;
                                        horizontal-alignment: left;
                                    }

                                    set-count := Text {
                                        x: set-label.width + 4px;
                                        y: 0px;
                                        width: min(self.preferred-width, max(0px, parent.width - self.x));
                                        height: parent.height;
                                        text: "(" + row.annotation-count + ")";
                                        color: Theme.text-secondary;
                                        font-size: 10px;
                                        font-weight: 500;
                                        vertical-alignment: center;
                                        horizontal-alignment: left;
                                    }
                                }

                                if !row.is-set: Text {
                                    x: 0px;
                                    y: 0px;
                                    width: parent.width;
                                    height: parent.height;
                                    text: row.label;
                                    color: row.visible ? rgb(row.color-r, row.color-g, row.color-b) : rgba(row.color-r, row.color-g, row.color-b, 0.65);
                                    font-size: 11px;
                                    font-weight: 400;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }

                            if row.is-set && !(root.editing-set-id == row.row-id): Rectangle {
                                width: 18px;
                                height: parent.height;
                                background: transparent;

                                TreeIconButton {
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                    icon-source: row.visible ? @image-url("icons/visible-true.svg") : @image-url("icons/visible-false.svg");
                                    tooltip-text: row.visible ? "Hide Annotation Set" : "Show Annotation Set";
                                    clicked => {
                                        root.confirm-active-rename();
                                        root.toggle-set-visibility(row.row-id, !row.visible);
                                    }
                                }
                            }

                            if row.is-set && !(root.editing-set-id == row.row-id): Rectangle {
                                width: 2px;
                                height: parent.height;
                                background: transparent;
                            }

                            if row.is-set && !(root.editing-set-id == row.row-id): Rectangle {
                                width: 18px;
                                height: parent.height;
                                background: transparent;

                                ColorSwatchButton {
                                    x: 0px;
                                    y: (parent.height - self.height) / 2;
                                    swatch-color: rgb(row.color-r, row.color-g, row.color-b);
                                    clicked => {
                                        root.confirm-active-rename();
                                        root.color-target-id = row.row-id;
                                        root.color-menu-x = self.absolute-position.x - root.absolute-position.x - 4px;
                                        root.color-menu-y = self.absolute-position.y - root.absolute-position.y + self.height + 8px;
                                        root.color-menu-visible = true;
                                        root.context-menu-visible = false;
                                    }
                                }
                            }
                        }
                    }
                }
            }

            if tree-flick.viewport-height > tree-flick.height + 1px: Rectangle {
                x: parent.width - self.width - 3px;
                y: 4px;
                width: 8px;
                height: parent.height - 8px;
                background: transparent;
                z: 2;

                property <length> max-scroll: max(0px, tree-flick.viewport-height - tree-flick.height);
                property <length> thumb-height: max(30px, (tree-flick.height * self.height) / max(tree-flick.viewport-height, tree-flick.height));
                property <length> thumb-travel: max(0px, self.height - self.thumb-height);
                property <float> scroll-progress: self.max-scroll <= 0px ? 0 : max(0, min(1, -tree-flick.viewport-y / self.max-scroll));
                property <length> thumb-y: self.scroll-progress * self.thumb-travel;

                function set-scroll-from-thumb(offset: length) {
                    let clamped = max(0px, min(self.thumb-travel, offset));
                    if self.thumb-travel <= 0px || self.max-scroll <= 0px {
                        tree-flick.viewport-y = 0px;
                    } else {
                        tree-flick.viewport-y = -(clamped * self.max-scroll / self.thumb-travel);
                    }
                }

                scrollbar-touch := TouchArea {
                    width: parent.width;
                    height: parent.height;
                    mouse-cursor: MouseCursor.default;

                    property <bool> dragging-thumb: false;
                    property <length> thumb-drag-offset: 0px;

                    pointer-event(e) => {
                        if e.button == PointerEventButton.left && e.kind == PointerEventKind.down {
                            if self.mouse-y >= parent.thumb-y && self.mouse-y <= parent.thumb-y + parent.thumb-height {
                                self.dragging-thumb = true;
                                self.thumb-drag-offset = self.mouse-y - parent.thumb-y;
                            } else {
                                self.dragging-thumb = true;
                                self.thumb-drag-offset = parent.thumb-height / 2;
                                parent.set-scroll-from-thumb(self.mouse-y - self.thumb-drag-offset);
                            }
                        } else if e.button == PointerEventButton.left && (e.kind == PointerEventKind.up || e.kind == PointerEventKind.cancel) {
                            self.dragging-thumb = false;
                            self.thumb-drag-offset = 0px;
                        }
                    }

                    moved => {
                        if self.dragging-thumb {
                            parent.set-scroll-from-thumb(self.mouse-y - self.thumb-drag-offset);
                        }
                    }
                }

                Rectangle {
                    x: 2.5px;
                    y: 0px;
                    width: 3px;
                    height: parent.height;
                    border-radius: self.width / 2;
                    background: scrollbar-touch.has-hover ? #1e252d : #191f26;
                }

                scrollbar-thumb := Rectangle {
                    x: 1.5px;
                    y: parent.thumb-y;
                    width: 5px;
                    height: parent.thumb-height;
                    border-radius: self.width / 2;
                    background: scrollbar-touch.dragging-thumb ? #9baabd : scrollbar-touch.has-hover ? #8797aa : #748396;
                }
            }
        }
    }

    if root.context-menu-visible: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: transparent;
        z: 15;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.confirm-active-rename();
                root.context-menu-visible = false;
            }
        }

        Rectangle {
            x: min(root.context-menu-x, max(0px, root.width - self.width - 8px));
            y: min(root.context-menu-y, max(0px, root.height - self.height - 8px));
            width: root.context-target-is-set ? 204px : 170px;
            height: root.context-target-is-set ? 64px : 32px;
            background: Theme.surface;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 10px;
            drop-shadow-color: #00000066;
            clip: true;
            z: 16;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                spacing: 1px;

                if root.context-target-is-set: ContextMenuRow {
                    label: "Rename";
                    clicked => {
                        root.queue-context-action(
                            "rename-local",
                            root.context-target-id,
                            root.context-target-name,
                            true,
                        );
                    }
                }

                ContextMenuRow {
                    label: root.context-target-is-set ? "Delete Annotation Set" : "Delete Annotation";
                    clicked => {
                        root.queue-context-action(
                            root.context-target-is-set ? "delete-set" : "delete-annotation",
                            root.context-target-id,
                            root.context-target-name,
                            root.context-target-is-set,
                        );
                    }
                }
            }
        }
    }

    if root.color-menu-visible: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: transparent;
        z: 15;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.confirm-active-rename();
                root.color-menu-visible = false;
            }
        }

        Rectangle {
            x: min(root.color-menu-x, max(0px, root.width - self.width - 8px));
            y: min(root.color-menu-y, max(0px, root.height - self.height - 8px));
            width: 118px;
            height: 150px;
            background: Theme.surface;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 10px;
            drop-shadow-color: #00000066;
            clip: true;
            z: 16;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding: 10px;
                spacing: 8px;

                Text {
                    text: "Set Color";
                    color: Theme.text-primary;
                    font-size: 11px;
                    font-weight: 600;
                }

                Rectangle {
                    width: 98px;
                    height: 98px;
                    background: transparent;

                    for entry[idx] in root.color-palette: PaletteSwatchButton {
                        x: (Math.mod(idx, 4) * 26) * 1px;
                        y: ((idx / 4) * 26) * 1px;
                        hex: entry.hex;
                        swatch-color: entry.swatch;
                        selected(hex) => {
                            root.set-set-color(root.color-target-id, hex);
                            root.color-menu-visible = false;
                        }
                    }
                }
            }
        }
    }

    if root.active-tooltip != "": Rectangle {
        x: max(4px, min(root.width - self.width - 4px, root.tooltip-center-x - self.width / 2));
        y: 42px;
        width: tooltip-text.preferred-width + 12px;
        height: tooltip-text.preferred-height + 6px;
        background: #101419f2;
        border-radius: 6px;
        border-width: 1px;
        border-color: Theme.border;
        z: 20;

        tooltip-text := Text {
            x: 6px;
            y: 3px;
            text: root.active-tooltip;
            color: Theme.text-primary;
            font-size: 11px;
        }
    }
}