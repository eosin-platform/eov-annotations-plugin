import { Theme } from "theme.slint";
import { ComboBox } from "std-widgets.slint";
import { AnnotationMetadataRow, AnnotationTreeRow, ColorPaletteEntry } from "annotations-sidebar-types.slint";
import {
    ColorSwatchButton,
    ContextMenuRow,
    ExportIconButton,
    PaletteSwatchButton,
    TreeIconButton,
} from "annotations-sidebar-widgets.slint";

export component AnnotationsSidebar inherits Rectangle {
    in property <[string]> source-options: ["Local"];
    in property <int> source-index: 0;
    in property <[AnnotationTreeRow]> tree-items: [];
    in property <string> empty-state-text: "";
    in property <bool> can-export: false;
    in property <bool> can-import: false;
    in property <bool> can-delete-set: false;
    in property <string> hovered-row-id: "";
    in property <bool> show-sha-mismatch-warning: false;
    in property <bool> show-import-conflict-dialog: false;
    in property <string> import-conflict-layer-name: "";
    in property <string> metadata-author: "";
    in property <string> metadata-organization: "";
    in property <string> metadata-project-name: "";
    in property <string> metadata-license: "";
    in-out property <string> selected-layer-id: "";
    in property <string> selected-layer-name: "";
    in property <bool> has-selected-annotation: false;
    in property <string> selected-annotation-name: "";
    in property <[AnnotationMetadataRow]> annotation-metadata-items: [];
    in-out property <string> editing-layer-id: "";
    property <int> metadata-focus-count: 0;
    out property <bool> capture-hotkeys: editing-layer-id != "" || metadata-focus-count > 0;
    property <length> tree-scroll-y: 0px;
    property <length> metadata-scroll-y: 0px;
    property <string> rename-draft-text: "";
    property <bool> settings-menu-visible: false;
    property <length> settings-menu-x: 0px;
    property <length> settings-menu-y: 0px;
    property <bool> dismiss-popups: false;
    property <bool> import-conflict-apply-all: false;
    property <string> pending-click-row-id: "";
    property <[ColorPaletteEntry]> color-palette: [
        { hex: "#FF355E", swatch: #FF355E },
        { hex: "#FF7A00", swatch: #FF7A00 },
        { hex: "#39FF14", swatch: #39FF14 },
        { hex: "#0057FF", swatch: #0057FF },
        { hex: "#6C63FF", swatch: #6C63FF },
        { hex: "#9D4EDD", swatch: #9D4EDD },
        { hex: "#FF4FD8", swatch: #FF4FD8 },
        { hex: "#F15BB5", swatch: #F15BB5 },
        { hex: "#43AA8B", swatch: #43AA8B },
        { hex: "#577590", swatch: #577590 },
        { hex: "#FF8A5B", swatch: #FF8A5B },
        { hex: "#FF6B6B", swatch: #FF6B6B },
        { hex: "#C77DFF", swatch: #C77DFF },
        { hex: "#B8F2E6", swatch: #B8F2E6 },
        { hex: "#F4A261", swatch: #F4A261 },
        { hex: "#FFFFFF", swatch: #FFFFFF },
    ];

    callback source-selected(string);
    callback create-layer-clicked();
    callback import-clicked();
    callback export-clicked();
    callback metadata-settings-requested();
    callback import-sha-warning-decided(bool);
    callback import-conflict-decided(string, bool);
    callback request-delete-layer(string, string);
    callback delete-layer-confirmed(string);
    callback delete-annotation-clicked(string);
    callback rename-layer-committed(string, string);
    callback rename-layer-cancelled();
    callback row-clicked(string);
    callback row-double-clicked(string);
    callback row-hovered(string);
    callback toggle-layer(string);
    callback toggle-layer-visibility(string, bool);
    callback set-layer-color(string, string);
    callback metadata-row-added();
    callback metadata-row-removed(int);
    callback metadata-row-key-changed(int, string);
    callback metadata-row-value-changed(int, string);

    property <bool> context-menu-visible: false;
    property <length> context-menu-x: 0px;
    property <length> context-menu-y: 0px;
    property <string> context-target-id: "";
    property <string> context-target-name: "";
    property <bool> context-target-is-layer: false;
    property <bool> context-target-is-empty-space: false;
    property <string> pending-context-action: "";
    property <string> pending-context-id: "";
    property <string> pending-context-name: "";
    property <bool> pending-context-is-layer: false;
    property <bool> color-menu-visible: false;
    property <length> color-menu-x: 0px;
    property <length> color-menu-y: 0px;
    property <string> color-target-id: "";
    property <string> active-tooltip:
        source-selector.has-focus ? "Source" : settings-button.hovered ? settings-button.tooltip-text : "";
    property <length> tooltip-center-x:
        source-selector.has-focus ? source-container.x + source-container.width / 2 : settings-button.hovered ? settings-button.x + settings-button.width / 2 : 0px;

    background: Theme.surface;

    sidebar-focus := FocusScope {
        width: 0px;
        height: 0px;
    }

    action-dispatch := Timer {
        interval: 1ms;
        running: false;
        triggered => {
            self.running = false;
            if root.pending-context-action == "rename-local" {
                root.editing-layer-id = root.pending-context-id;
            } else if root.pending-context-action == "create-layer" {
                root.create-layer-clicked();
            } else if root.pending-context-action == "delete-set" {
                root.request-delete-layer(root.pending-context-id, root.pending-context-name);
            } else if root.pending-context-action == "delete-annotation" {
                root.delete-annotation-clicked(root.pending-context-id);
            }
            root.pending-context-action = "";
            root.pending-context-id = "";
            root.pending-context-name = "";
            root.pending-context-is-layer = false;
        }
    }

    click-window := Timer {
        interval: 280ms;
        running: false;
        triggered => {
            self.running = false;
            root.pending-click-row-id = "";
        }
    }

    function confirm-active-rename() {
        if root.editing-layer-id != "" {
            root.rename-layer-committed(root.editing-layer-id, root.rename-draft-text);
            root.editing-layer-id = "";
        }
    }

    function open-context-menu(target-id: string, target-name: string, is-layer: bool, local-x: length, local-y: length) {
        root.context-target-id = target-id;
        root.context-target-name = target-name;
        root.context-target-is-layer = is-layer;
        root.context-target-is-empty-space = false;
        root.context-menu-x = local-x;
        root.context-menu-y = local-y;
        root.context-menu-visible = true;
        root.color-menu-visible = false;
    }

    function open-empty-space-context-menu(local-x: length, local-y: length) {
        root.context-target-id = "";
        root.context-target-name = "";
        root.context-target-is-layer = false;
        root.context-target-is-empty-space = true;
        root.context-menu_x = local-x;
        root.context-menu_y = local-y;
        root.context-menu-visible = true;
        root.color-menu-visible = false;
    }

    function queue-context-action(action: string, target-id: string, target-name: string, is-layer: bool) {
        root.pending-context-action = action;
        root.pending-context-id = target-id;
        root.pending-context-name = target-name;
        root.pending-context-is-layer = is-layer;
        root.context-menu-visible = false;
        root.context-target-is-empty-space = false;
        action-dispatch.start();
    }

    function open-settings-menu(local-x: length, local-y: length) {
        root.settings-menu-x = local-x;
        root.settings-menu-y = local-y;
        root.settings-menu-visible = true;
        root.context-menu-visible = false;
        root.color-menu-visible = false;
    }

    changed dismiss-popups => {
        if root.dismiss-popups {
            root.confirm-active-rename();
            root.settings-menu-visible = false;
            root.context-menu-visible = false;
            root.color-menu-visible = false;
            root.dismiss-popups = false;
        }
    }

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-top: 10px;
        padding-right: 10px;
        padding-bottom: 10px;
        padding-left: 10px;
        spacing: 10px;

        HorizontalLayout {
            spacing: 8px;

            source-container := Rectangle {
                horizontal-stretch: 1;
                height: 28px;
                background: transparent;

                source-selector := ComboBox {
                    width: parent.width;
                    height: parent.height;
                    model: root.source-options;
                    current-index: root.source-index;
                    selected(index) => {
                        root.source-selected(index);
                    }
                }
            }

            create-layer-button := ExportIconButton {
                icon-source: @image-url("icons/new_annotation_layer.svg");
                tooltip-text: "Create Annotation Layer";
                enabled: root.can-export || root.can-import;
                clicked => {
                    root.confirm-active-rename();
                    root.create-layer-clicked();
                }
            }

            settings-button := ExportIconButton {
                icon-source: @image-url("icons/settings.svg");
                tooltip-text: "Settings";
                enabled: root.can-export || root.can-import;
                clicked => {
                    root.confirm-active-rename();
                    root.open-settings-menu(
                        self.absolute-position.x - root.absolute-position.x,
                        self.absolute-position.y - root.absolute-position.y + self.height + 8px,
                    );
                }
            }
        }

        VerticalLayout {
            vertical-stretch: 1;
            spacing: 10px;

            Rectangle {
                vertical-stretch: 2;
                background: transparent;
                border-radius: 4px;
                border-width: 1px;
                border-color: Theme.border;

                if root.tree-items.length == 0: Rectangle {
                    width: parent.width;
                    height: parent.height;
                    background: transparent;

                    Text {
                        x: 14px;
                        y: 14px;
                        width: parent.width - 28px;
                        text: root.empty-state-text;
                        color: Theme.text-secondary;
                        font-size: 12px;
                        wrap: word-wrap;
                    }
                }

                tree-flick := Flickable {
                    width: parent.width;
                    height: parent.height;
                    viewport-height: tree-layout.preferred-height;
                    viewport-y: root.tree-scroll-y;
                    interactive: root.tree-items.length > 0;

                    changed viewport-y => {
                        root.tree-scroll-y = self.viewport-y;
                    }

                    tree-layout := VerticalLayout {
                        width: parent.width;
                        spacing: 0px;

                        for row[idx] in root.tree-items: Rectangle {
                            width: parent.width;
                            height: 32px;
                            background: row.is-selected ? #4da3d930 : (row-touch.has-hover || root.hovered-row-id == row.row-id) ? #ffffff10 : transparent;

                            row-touch := TouchArea {
                                changed has-hover => {
                                    if row.is-layer {
                                        if self.has-hover || root.hovered-row-id == row.row-id {
                                            root.row-hovered("");
                                        }
                                    } else {
                                        root.row-hovered(self.has-hover ? row.row-id : "");
                                    }
                                }

                                clicked => {
                                    root.confirm-active-rename();
                                    if click-window.running && root.pending-click-row-id == row.row-id {
                                        click-window.running = false;
                                        root.pending-click-row-id = "";
                                        if row.is-layer {
                                            root.selected-layer-id = row.row-id;
                                            root.rename-draft-text = row.label;
                                            root.editing-layer-id = row.row-id;
                                        } else {
                                            root.selected-layer-id = row.parent-layer-id;
                                            root.row-double-clicked(row.row-id);
                                        }
                                    } else {
                                        root.selected-layer-id = row.is-layer ? row.row-id : row.parent-layer-id;
                                        root.row-clicked(row.row-id);
                                        root.pending-click-row-id = row.row-id;
                                        click-window.running = false;
                                        click-window.running = true;
                                    }
                                }

                                pointer-event(e) => {
                                    if e.kind == PointerEventKind.down && e.button == PointerEventButton.right {
                                        root.confirm-active-rename();
                                        root.open-context-menu(
                                            row.row-id,
                                            row.label,
                                            row.is-layer,
                                            self.absolute-position.x + self.mouse-x - root.absolute-position.x,
                                            self.absolute-position.y + self.mouse-y - root.absolute-position.y,
                                        );
                                    }
                                }
                            }

                            HorizontalLayout {
                                padding-left: (8 + row.indent * 18) * 1px;
                                padding-right: 6px;
                                spacing: 1px;

                                if row.is-layer: Rectangle {
                                    width: 12px;
                                    height: parent.height;
                                    background: transparent;

                                    Text {
                                        text: row.is-collapsed ? "▸" : "▾";
                                        color: Theme.text-secondary;
                                        font-size: 12px;
                                        vertical-alignment: center;
                                    }

                                    set-expander-touch := TouchArea {
                                        width: parent.width;
                                        height: parent.height;
                                        clicked => {
                                            root.toggle-layer(row.row-id);
                                        }
                                    }
                                }

                                if !row.is-layer: Rectangle {
                                    width: 12px;
                                    height: parent.height;
                                    background: transparent;
                                    opacity: row.visible ? 1.0 : 0.65;

                                    Rectangle {
                                        x: 3px;
                                        y: (parent.height - self.height) / 2;
                                        width: 6px;
                                        height: 6px;
                                        border-radius: 3px;
                                        background: rgb(row.color-r, row.color-g, row.color-b);
                                    }
                                }

                                if root.editing-layer-id == row.row-id && row.is-layer: Rectangle {
                                    horizontal-stretch: 1;
                                    height: 22px;
                                    y: (parent.height - self.height) / 2;
                                    background: root.selected-layer-id == row.row-id ? #0f1419f2 : #11161d;
                                    border-radius: 3px;
                                    border-width: 1px;
                                    border-color: rename-input.has-focus ? Theme.accent : #ffffff24;

                                    rename-input := TextInput {
                                        x: 5px;
                                        y: 2px;
                                        width: parent.width - 10px;
                                        height: parent.height - 4px;
                                        text: row.label;
                                        changed text => {
                                            root.rename-draft-text = self.text;
                                        }
                                        font-size: 12px;
                                        color: Theme.text-primary;
                                        selection-background-color: Theme.accent;
                                        selection-foreground-color: #ffffff;
                                        text-cursor-width: 1px;
                                        vertical-alignment: center;
                                        accepted => {
                                            root.confirm-active-rename();
                                        }
                                        key-pressed(e) => {
                                            if e.text == Key.Escape {
                                                root.rename-layer-cancelled();
                                                root.editing-layer-id = "";
                                                accept
                                            } else {
                                                reject
                                            }
                                        }
                                        changed has-focus => {
                                            if !self.has-focus && root.editing-layer-id == row.row-id {
                                                root.confirm-active-rename();
                                            }
                                        }
                                    }

                                    focus-rename-input := Timer {
                                        interval: 1ms;
                                        running: true;
                                        triggered => {
                                            self.running = false;
                                            root.rename-draft-text = row.label;
                                            rename-input.focus();
                                            rename-input.select-all();
                                        }
                                    }
                                }

                                if !(root.editing-layer-id == row.row-id && row.is-layer): Rectangle {
                                    horizontal-stretch: 1;
                                    vertical-stretch: 1;
                                    background: transparent;

                                    if row.is-layer: Rectangle {
                                        width: parent.width;
                                        height: parent.height;
                                        background: transparent;

                                        set-label := Text {
                                            x: 0px;
                                            y: 0px;
                                            width: min(self.preferred-width, max(0px, parent.width - 4px - set-count.preferred-width));
                                            height: parent.height;
                                            text: row.label;
                                            color: row.visible ? Theme.text-primary : Theme.text-secondary;
                                            font-size: 12px;
                                            font-weight: 600;
                                            vertical-alignment: center;
                                            overflow: elide;
                                            horizontal-alignment: left;
                                        }

                                        set-count := Text {
                                            x: set-label.width + 4px;
                                            y: 0px;
                                            width: min(self.preferred-width, max(0px, parent.width - self.x));
                                            height: parent.height;
                                            text: "(" + row.annotation-count + ")";
                                            color: Theme.text-secondary;
                                            font-size: 10px;
                                            font-weight: 500;
                                            vertical-alignment: center;
                                            horizontal-alignment: left;
                                        }
                                    }

                                    if !row.is-layer: Text {
                                        x: 0px;
                                        y: 0px;
                                        width: parent.width;
                                        height: parent.height;
                                        text: row.label;
                                        color: row.visible ? rgb(row.color-r, row.color-g, row.color-b) : rgba(row.color-r, row.color-g, row.color-b, 0.65);
                                        font-size: 11px;
                                        font-weight: 400;
                                        vertical-alignment: center;
                                        overflow: elide;
                                    }
                                }

                                if row.is-layer && !(root.editing-layer-id == row.row-id): Rectangle {
                                    width: 18px;
                                    height: parent.height;
                                    background: transparent;

                                    TreeIconButton {
                                        x: (parent.width - self.width) / 2;
                                        y: (parent.height - self.height) / 2;
                                        icon-source: row.visible ? @image-url("icons/visible-true.svg") : @image-url("icons/visible-false.svg");
                                        tooltip-text: row.visible ? "Hide Annotation Layer" : "Show Annotation Layer";
                                        clicked => {
                                            root.confirm-active-rename();
                                            root.toggle-layer-visibility(row.row-id, !row.visible);
                                        }
                                    }
                                }

                                if row.is-layer && !(root.editing-layer-id == row.row-id): Rectangle {
                                    width: 2px;
                                    height: parent.height;
                                    background: transparent;
                                }

                                if row.is-layer && !(root.editing-layer-id == row.row-id): Rectangle {
                                    width: 18px;
                                    height: parent.height;
                                    background: transparent;

                                    ColorSwatchButton {
                                        x: 0px;
                                        y: (parent.height - self.height) / 2;
                                        swatch-color: rgb(row.color-r, row.color-g, row.color-b);
                                        clicked => {
                                            root.confirm-active-rename();
                                            root.color-target-id = row.row-id;
                                            root.color-menu-x = self.absolute-position.x - root.absolute-position.x - 4px;
                                            root.color-menu-y = self.absolute-position.y - root.absolute-position.y + self.height + 8px;
                                            root.color-menu-visible = true;
                                            root.context-menu-visible = false;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                if tree-flick.viewport-height + tree-flick.viewport-y < parent.height: Rectangle {
                    x: 0px;
                    y: max(0px, tree-flick.viewport-height + tree-flick.viewport-y);
                    width: parent.width;
                    height: parent.height - self.y;
                    background: transparent;

                    empty-margin-touch := TouchArea {
                        clicked => {
                            root.confirm-active-rename();
                        }

                        pointer-event(e) => {
                            if e.kind == PointerEventKind.down && e.button == PointerEventButton.right {
                                root.confirm-active-rename();
                                root.open-empty-space-context-menu(
                                    self.absolute-position.x + self.mouse-x - root.absolute-position.x,
                                    self.absolute-position.y + self.mouse-y - root.absolute-position.y,
                                );
                            }
                        }
                    }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                background: #0f1419;
                border-radius: 4px;
                border-width: 1px;
                border-color: Theme.border;

                VerticalLayout {
                    width: parent.width;
                    height: parent.height;
                    padding: 10px;
                    spacing: 8px;

                    Text {
                        text: root.has-selected-annotation ? "Metadata for '" + root.selected-annotation-name + "'" : "Metadata";
                        color: Theme.text-primary;
                        font-size: 12px;
                        font-weight: 600;
                    }

                    if !root.has-selected-annotation: Text {
                        text: "Select an annotation to edit its metadata.";
                        color: Theme.text-secondary;
                        font-size: 11px;
                        wrap: word-wrap;
                    }

                    if root.has-selected-annotation: Rectangle {
                        height: 24px;
                        background: #121922;
                        border-radius: 3px;
                        border-width: 1px;
                        border-color: #ffffff14;

                        HorizontalLayout {
                            padding-left: 8px;
                            padding-right: 8px;
                            spacing: 8px;

                            Text {
                                width: (parent.width - 44px) / 2;
                                text: "Key";
                                color: Theme.text-secondary;
                                font-size: 10px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }

                            Text {
                                width: (parent.width - 44px) / 2;
                                text: "Value";
                                color: Theme.text-secondary;
                                font-size: 10px;
                                font-weight: 600;
                                vertical-alignment: center;
                            }

                            Rectangle {
                                width: 20px;
                                background: transparent;
                            }
                        }
                    }

                    if root.has-selected-annotation: Rectangle {
                        vertical-stretch: 1;
                        background: transparent;
                        border-radius: 3px;
                        border-width: 1px;
                        border-color: #ffffff14;

                        metadata-flick := Flickable {
                            width: parent.width;
                            height: parent.height;
                            viewport-height: metadata-layout.preferred-height;
                            viewport-y: root.metadata-scroll-y;
                            interactive: root.annotation-metadata-items.length > 0;

                            changed viewport-y => {
                                root.metadata-scroll-y = self.viewport-y;
                            }

                            metadata-layout := VerticalLayout {
                                width: parent.width;
                                spacing: 1px;

                                for entry[idx] in root.annotation-metadata-items: Rectangle {
                                    width: parent.width;
                                    height: 34px;
                                    background: metadata-touch.has-hover ? #ffffff10 : transparent;

                                    metadata-touch := TouchArea {}

                                    HorizontalLayout {
                                        padding: 6px;
                                        spacing: 6px;

                                        Rectangle {
                                            width: (parent.width - 36px) / 2;
                                            height: 22px;
                                            background: #0b1016;
                                            border-radius: 3px;
                                            border-width: 1px;
                                            border-color: key-input.has-focus ? Theme.accent : #ffffff18;

                                            key-input := TextInput {
                                                x: 6px;
                                                y: 2px;
                                                width: parent.width - 12px;
                                                height: parent.height - 4px;
                                                text: entry.key;
                                                font-size: 11px;
                                                color: Theme.text-primary;
                                                selection-background-color: Theme.accent;
                                                selection-foreground-color: #ffffff;
                                                vertical-alignment: center;
                                                accepted => {
                                                    root.metadata-row-key-changed(idx, self.text);
                                                    value-input.focus();
                                                    value-input.select-all();
                                                }
                                                changed has-focus => {
                                                    root.metadata-focus-count = self.has-focus ? root.metadata-focus-count + 1 : max(0, root.metadata-focus-count - 1);
                                                    if !self.has-focus {
                                                        root.metadata-row-key-changed(idx, self.text);
                                                    }
                                                }
                                            }
                                        }

                                        Rectangle {
                                            width: (parent.width - 36px) / 2;
                                            height: 22px;
                                            background: #0b1016;
                                            border-radius: 3px;
                                            border-width: 1px;
                                            border-color: value-input.has-focus ? Theme.accent : #ffffff18;

                                            value-input := TextInput {
                                                x: 6px;
                                                y: 2px;
                                                width: parent.width - 12px;
                                                height: parent.height - 4px;
                                                text: entry.value;
                                                font-size: 11px;
                                                color: Theme.text-primary;
                                                selection-background-color: Theme.accent;
                                                selection-foreground-color: #ffffff;
                                                vertical-alignment: center;
                                                accepted => {
                                                    root.metadata-row-value-changed(idx, self.text);
                                                    sidebar-focus.focus();
                                                }
                                                changed has-focus => {
                                                    root.metadata-focus-count = self.has-focus ? root.metadata-focus-count + 1 : max(0, root.metadata-focus-count - 1);
                                                    if !self.has-focus {
                                                        root.metadata-row-value-changed(idx, self.text);
                                                    }
                                                }
                                            }
                                        }

                                        Rectangle {
                                            width: 18px;
                                            height: 18px;
                                            y: (parent.height - self.height) / 2;
                                            border-radius: 9px;
                                            background: remove-touch.has-hover ? #ffffff12 : transparent;

                                            remove-touch := TouchArea {
                                                clicked => {
                                                    root.metadata-row-removed(idx);
                                                }
                                            }

                                            Text {
                                                text: "×";
                                                color: Theme.text-secondary;
                                                font-size: 12px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }

                    if root.has-selected-annotation: Rectangle {
                        height: 28px;
                        border-radius: 4px;
                        background: add-metadata-row-touch.has-hover ? Theme.surface-hover : Theme.surface;
                        border-width: 1px;
                        border-color: Theme.border;

                        add-metadata-row-touch := TouchArea {
                            clicked => {
                                root.metadata-row-added();
                            }
                        }

                        Text {
                            text: "Add metadata row";
                            color: Theme.text-primary;
                            font-size: 11px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    if root.settings-menu-visible: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: transparent;
        z: 15;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.confirm-active-rename();
                root.settings-menu-visible = false;
            }
        }

        Rectangle {
            x: min(root.settings-menu-x, max(0px, root.width - self.width - 8px));
            y: min(root.settings-menu-y, max(0px, root.height - self.height - 8px));
            width: 196px;
            height: 136px;
            background: Theme.surface;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 10px;
            drop-shadow-color: #00000066;
            clip: true;
            z: 16;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding-top: 4px;
                padding-bottom: 4px;
                spacing: 0px;

                ContextMenuRow {
                    label: "New Annotation Layer";
                    enabled: root.can-export || root.can-import;
                    clicked => {
                        root.settings-menu-visible = false;
                        root.confirm-active-rename();
                        root.create-layer-clicked();
                    }
                }

                ContextMenuRow {
                    label: "Import Annotations";
                    enabled: root.can-import;
                    clicked => {
                        root.settings-menu-visible = false;
                        root.confirm-active-rename();
                        root.import-clicked();
                    }
                }

                ContextMenuRow {
                    label: "Export Annotations";
                    enabled: root.can-export;
                    clicked => {
                        root.settings-menu-visible = false;
                        root.confirm-active-rename();
                        root.export-clicked();
                    }
                }

                ContextMenuRow {
                    label: "Metadata Settings";
                    enabled: root.can-export || root.can-import;
                    clicked => {
                        root.settings-menu-visible = false;
                        root.confirm-active-rename();
                        root.metadata-settings-requested();
                    }
                }
            }
        }
    }

    if root.context-menu-visible: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: transparent;
        z: 15;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.confirm-active-rename();
                root.context-menu-visible = false;
            }
        }

        Rectangle {
            x: min(root.context-menu-x, max(0px, root.width - self.width - 8px));
            y: min(root.context-menu-y, max(0px, root.height - self.height - 8px));
            width: root.context-target-is-empty-space ? 180px : root.context-target-is-layer ? 204px : 170px;
            height: root.context-target-is-empty-space ? 32px : root.context-target-is-layer ? 64px : 32px;
            background: Theme.surface;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 10px;
            drop-shadow-color: #00000066;
            clip: true;
            z: 16;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                spacing: 1px;

                if root.context-target-is-empty-space: ContextMenuRow {
                    label: "Create Annotation Layer";
                    clicked => {
                        root.queue-context-action("create-layer", "", "", false);
                    }
                }

                if root.context-target-is-layer && !root.context-target-is-empty-space: ContextMenuRow {
                    label: "Rename";
                    clicked => {
                        root.queue-context-action(
                            "rename-local",
                            root.context-target-id,
                            root.context-target-name,
                            true,
                        );
                    }
                }

                if !root.context-target-is-empty-space: ContextMenuRow {
                    label: root.context-target-is-layer ? "Delete Annotation Layer" : "Delete Annotation";
                    clicked => {
                        root.queue-context-action(
                            root.context-target-is-layer ? "delete-set" : "delete-annotation",
                            root.context-target-id,
                            root.context-target-name,
                            root.context-target-is-layer,
                        );
                    }
                }
            }
        }
    }

    if root.color-menu-visible: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: transparent;
        z: 15;

        TouchArea {
            width: parent.width;
            height: parent.height;
            clicked => {
                root.confirm-active-rename();
                root.color-menu-visible = false;
            }
        }

        Rectangle {
            x: min(root.color-menu-x, max(0px, root.width - self.width - 8px));
            y: min(root.color-menu-y, max(0px, root.height - self.height - 8px));
            width: 118px;
            height: 150px;
            background: Theme.surface;
            border-radius: 6px;
            border-width: 1px;
            border-color: Theme.border;
            drop-shadow-blur: 10px;
            drop-shadow-color: #00000066;
            clip: true;
            z: 16;

            VerticalLayout {
                width: parent.width;
                height: parent.height;
                padding: 10px;
                spacing: 8px;

                Text {
                    text: "Set Color";
                    color: Theme.text-primary;
                    font-size: 11px;
                    font-weight: 600;
                }

                Rectangle {
                    width: 98px;
                    height: 98px;
                    background: transparent;

                    for entry[idx] in root.color-palette: PaletteSwatchButton {
                        x: (Math.mod(idx, 4) * 26) * 1px;
                        y: (Math.floor(idx / 4) * 26) * 1px;
                        hex: entry.hex;
                        swatch-color: entry.swatch;
                        selected(hex) => {
                            root.set-layer-color(root.color-target-id, hex);
                            root.color-menu-visible = false;
                        }
                    }
                }
            }
        }
    }

    if root.active-tooltip != "": Rectangle {
        x: max(4px, min(root.width - self.width - 4px, root.tooltip-center-x - self.width / 2));
        y: 42px;
        width: tooltip-text.preferred-width + 12px;
        height: tooltip-text.preferred-height + 6px;
        background: #101419f2;
        border-radius: 6px;
        border-width: 1px;
        border-color: Theme.border;
        z: 20;

        tooltip-text := Text {
            x: 6px;
            y: 3px;
            text: root.active-tooltip;
            color: Theme.text-primary;
            font-size: 11px;
        }
    }

    if root.show-sha-mismatch-warning: Rectangle {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        background: #00000088;
        z: 30;

        TouchArea { }

        Rectangle {
            x: 12px;
            y: max(12px, (parent.height - self.height) / 2);
            width: parent.width - 24px;
            height: 186px;
            background: Theme.surface;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.border;

            TouchArea { }

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text {
                    text: "Warning";
                    color: Theme.text-primary;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: left;
                }

                Text {
                    text: "Warning: the annotations file being imported is based on a different WSI file. Are you sure you want to continue?";
                    color: Theme.text-secondary;
                    font-size: 12px;
                    wrap: word-wrap;
                    horizontal-alignment: left;
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    Rectangle {
                        min-width: 64px;
                        height: 28px;
                        border-radius: 4px;
                        background: cancel-sha-touch.has-hover ? Theme.surface-hover : Theme.surface;
                        border-width: 1px;
                        border-color: Theme.border;

                        cancel-sha-touch := TouchArea {
                            clicked => {
                                root.import-sha-warning-decided(false);
                            }
                        }

                        Text {
                            text: "Cancel";
                            color: Theme.text-primary;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        min-width: 64px;
                        height: 28px;
                        border-radius: 4px;
                        background: import-sha-touch.has-hover ? #1177bb : Theme.accent;

                        import-sha-touch := TouchArea {
                            clicked => {
                                root.import-sha-warning-decided(true);
                            }
                        }

                        Text {
                            text: "Import";
                            color: white;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

    if root.show-import-conflict-dialog: Rectangle {
        x: 0px;
        y: 0px;
        width: root.width;
        height: root.height;
        background: #00000088;
        z: 30;

        TouchArea { }

        Rectangle {
            x: 12px;
            y: max(12px, (parent.height - self.height) / 2);
            width: parent.width - 24px;
            height: 226px;
            background: Theme.surface;
            border-radius: 8px;
            border-width: 1px;
            border-color: Theme.border;

            TouchArea { }

            VerticalLayout {
                padding: 16px;
                spacing: 12px;

                Text {
                    text: "Import Conflict";
                    color: Theme.text-primary;
                    font-size: 14px;
                    font-weight: 600;
                    horizontal-alignment: left;
                }

                Text {
                    text: "Annotation Layer '" + root.import-conflict-layer-name + "' already exists for the current slide.";
                    color: Theme.text-secondary;
                    font-size: 12px;
                    wrap: word-wrap;
                    horizontal-alignment: left;
                }

                Rectangle {
                    height: 28px;
                    background: transparent;

                    conflict-apply-all-touch := TouchArea {
                        clicked => {
                            root.import-conflict-apply-all = !root.import-conflict-apply-all;
                        }
                    }

                    Rectangle {
                        x: 0px;
                        y: 6px;
                        width: 14px;
                        height: 14px;
                        border-radius: 3px;
                        border-width: 1px;
                        border-color: root.import-conflict-apply-all ? Theme.accent : Theme.border;
                        background: root.import-conflict-apply-all ? Theme.accent : Theme.surface;

                        Text {
                            text: root.import-conflict-apply-all ? "✓" : "";
                            color: white;
                            font-size: 10px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        x: 22px;
                        y: 5px;
                        text: "Apply to all conflicts";
                        color: Theme.text-primary;
                        font-size: 12px;
                    }
                }

                Rectangle {
                    vertical-stretch: 1;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    for action in [
                        { label: "Merge", id: "merge", primary: false },
                        { label: "Replace", id: "replace", primary: false },
                        { label: "Skip", id: "skip", primary: false },
                        { label: "Cancel", id: "cancel", primary: true }
                    ]: Rectangle {
                        min-width: action.label == "Replace" ? 70px : 62px;
                        height: 28px;
                        border-radius: 4px;
                        background: action.primary ? (action-touch.has-hover ? Theme.surface-hover : Theme.surface) : (action-touch.has-hover ? #1177bb : Theme.accent);
                        border-width: action.primary ? 1px : 0px;
                        border-color: Theme.border;

                        action-touch := TouchArea {
                            clicked => {
                                root.import-conflict-decided(action.id, root.import-conflict-apply-all);
                                root.import-conflict-apply-all = false;
                            }
                        }

                        Text {
                            text: action.label;
                            color: action.primary ? Theme.text-primary : white;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }

}