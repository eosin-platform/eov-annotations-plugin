export struct AnnotationTreeRow {
    row-id: string,
    parent-layer-id: string,
    label: string,
    annotation-count: int,
    indent: int,
    is-layer: bool,
    is-collapsed: bool,
    is-selected: bool,
    visible: bool,
    color-hex: string,
    color-r: int,
    color-g: int,
    color-b: int,
}

export struct ColorPaletteEntry {
    hex: string,
    swatch: color,
}

export struct AnnotationMetadataRow {
    key: string,
    value: string,
}