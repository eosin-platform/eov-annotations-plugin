import { Theme } from "theme.slint";

component MetadataInputField inherits Rectangle {
    in property <string> label: "";
    in-out property <string> value: "";
    out property <bool> has-active-input: input.has-focus;

    width: 100%;
    height: 64px;
    background: transparent;

    Text {
        x: 0px;
        y: 0px;
        width: parent.width;
        text: root.label;
        color: Theme.text-secondary;
        font-size: 11px;
    }

    Rectangle {
        x: 0px;
        y: 22px;
        width: parent.width;
        height: 36px;
        background: #101419;
        border-radius: 6px;
        border-width: 1px;
        border-color: input.has-focus ? Theme.accent : Theme.border;

        input := TextInput {
            x: 10px;
            y: 0px;
            width: parent.width - 20px;
            height: parent.height;
            text <=> root.value;
            color: Theme.text-primary;
            font-size: 12px;
            selection-background-color: Theme.accent;
            selection-foreground-color: #ffffff;
            text-cursor-width: 1px;
            vertical-alignment: center;
        }
    }
}

export component MetadataSettingsDialog inherits Rectangle {
    in property <string> metadata-author: "";
    in property <string> metadata-organization: "";
    in property <string> metadata-project-name: "";
    in property <string> metadata-license: "";

    property <string> metadata-author-draft: root.metadata-author;
    property <string> metadata-organization-draft: root.metadata-organization;
    property <string> metadata-project-name-draft: root.metadata-project-name;
    property <string> metadata-license-draft: root.metadata-license;

    callback metadata-settings-confirmed(string, string, string, string);
    callback metadata-settings-cancelled();

    out property <bool> capture-hotkeys:
        author-field.has-active-input
        || organization-field.has-active-input
        || project-name-field.has-active-input
        || license-field.has-active-input;

    background: transparent;

    panel := Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: Theme.surface;
        border-radius: 10px;
        border-width: 1px;
        border-color: Theme.border;
        clip: true;

        VerticalLayout {
            x: 20px;
            y: 20px;
            width: parent.width - 40px;
            height: parent.height - 40px;
            spacing: 12px;

            Text {
                width: parent.width;
                text: "Metadata Settings";
                color: Theme.text-primary;
                font-size: 14px;
                font-weight: 600;
                horizontal-alignment: left;
            }

            author-field := MetadataInputField {
                label: "Author";
                value <=> root.metadata-author-draft;
            }

            organization-field := MetadataInputField {
                label: "Organization";
                value <=> root.metadata-organization-draft;
            }

            project-name-field := MetadataInputField {
                label: "Project Name";
                value <=> root.metadata-project-name-draft;
            }

            license-field := MetadataInputField {
                label: "License";
                value <=> root.metadata-license-draft;
            }

            Rectangle {
                vertical-stretch: 1;
                background: transparent;
            }

            HorizontalLayout {
                width: parent.width;
                spacing: 8px;
                alignment: end;

                Rectangle {
                    min-width: 72px;
                    height: 32px;
                    border-radius: 6px;
                    background: cancel-touch.has-hover ? Theme.surface-hover : Theme.surface;
                    border-width: 1px;
                    border-color: Theme.border;

                    cancel-touch := TouchArea {
                        clicked => {
                            root.metadata-settings-cancelled();
                        }
                    }

                    Text {
                        width: parent.width;
                        height: parent.height;
                        text: "Cancel";
                        color: Theme.text-primary;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }

                Rectangle {
                    min-width: 80px;
                    height: 32px;
                    border-radius: 6px;
                    background: confirm-touch.has-hover ? #1177bb : Theme.accent;

                    confirm-touch := TouchArea {
                        clicked => {
                            root.metadata-settings-confirmed(
                                root.metadata-author-draft,
                                root.metadata-organization-draft,
                                root.metadata-project-name-draft,
                                root.metadata-license-draft,
                            );
                        }
                    }

                    Text {
                        width: parent.width;
                        height: parent.height;
                        text: "Confirm";
                        color: white;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }
        }
    }
}